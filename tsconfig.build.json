{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"allowImportingTsExtensions": false,
		"declaration": true,
		"declarationMap": true,
		"module": "Node16",
		"moduleResolution": "node16",
		"noEmit": false,
		"outDir": "./dist",
		"rootDir": "./src",
		"sourceMap": true,
		"verbatimModuleSyntax": false
	},
	"include": ["./src/**/*.ts"],
	"exclude": ["./tests/**/*.ts"]
}
